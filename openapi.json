{
  "openapi": "3.1.0",
  "info": {
    "title": "Crypto Analysis API",
    "description": "API for coin chart data and AI-generated structured ticker reports. Only supported tickers are allowed.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/chart-data": {
      "post": {
        "summary": "Get Chart Data",
        "operationId": "get_chart_data_api_v1_chart_data_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChartDataResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/report": {
      "post": {
        "summary": "Get Structured Report",
        "operationId": "get_structured_report_api_v1_report_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChartDataResponse": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "coin_id": {
            "type": "string",
            "title": "Coin Id"
          },
          "series": {
            "additionalProperties": {
              "$ref": "#/components/schemas/ChartSeries"
            },
            "type": "object",
            "title": "Series"
          }
        },
        "type": "object",
        "required": [
          "query",
          "ticker",
          "coin_id",
          "series"
        ],
        "title": "ChartDataResponse"
      },
      "ChartPoint": {
        "properties": {
          "timestamp_ms": {
            "type": "integer",
            "title": "Timestamp Ms"
          },
          "price_usd": {
            "type": "number",
            "title": "Price Usd"
          }
        },
        "type": "object",
        "required": [
          "timestamp_ms",
          "price_usd"
        ],
        "title": "ChartPoint"
      },
      "ChartRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query",
            "description": "Natural-language user request"
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "ChartRequest"
      },
      "ChartSeries": {
        "properties": {
          "timeframe": {
            "type": "string",
            "title": "Timeframe"
          },
          "points": {
            "items": {
              "$ref": "#/components/schemas/ChartPoint"
            },
            "type": "array",
            "title": "Points"
          }
        },
        "type": "object",
        "required": [
          "timeframe",
          "points"
        ],
        "title": "ChartSeries"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ReportRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query",
            "description": "Natural-language user request"
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "ReportRequest"
      },
      "ReportResponse": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "coin_id": {
            "type": "string",
            "title": "Coin Id"
          },
          "report_markdown": {
            "type": "string",
            "title": "Report Markdown"
          },
          "sections": {
            "items": {
              "$ref": "#/components/schemas/ReportSection"
            },
            "type": "array",
            "title": "Sections"
          },
          "analysis": {
            "type": "string",
            "title": "Analysis"
          },
          "errors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Errors"
          }
        },
        "type": "object",
        "required": [
          "ticker",
          "coin_id",
          "report_markdown",
          "sections",
          "analysis",
          "errors"
        ],
        "title": "ReportResponse"
      },
      "ReportSection": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "title",
          "content"
        ],
        "title": "ReportSection"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}